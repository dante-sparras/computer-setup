// Zellij configuration
// Theme: onedark (matches common editor themes)

theme "onedark"

default_layout "compact"
default_shell "zsh"

copy_on_select true
mouse_mode true

keybinds {
    normal {
        bind "Ctrl h" { MoveFocus "left"; }
        bind "Ctrl l" { MoveFocus "right"; }
        bind "Ctrl j" { MoveFocus "down"; }
        bind "Ctrl k" { MoveFocus "up"; }
    }
}