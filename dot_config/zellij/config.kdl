// Zellij configuration
// Theme: onedark (matches common editor themes)

theme "onedark"

default_layout "compact"
default_shell "zsh"

copy_on_select true
mouse_mode true

keybinds {
    normal {
        "Ctrl h" { MoveFocus "Left"; }
        "Ctrl l" { MoveFocus "Right"; }
        "Ctrl j" { MoveFocus "Down"; }
        "Ctrl k" { MoveFocus "Up"; }
    }
}