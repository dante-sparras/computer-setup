// Zellij configuration
// Theme: onedark (matches common editor themes)

theme "onedark"

default_layout "compact"
default_shell "zsh"

copy_on_select true
mouse_mode true

keybinds {
    normal {
        // Use Alt + hjkl for pane navigation to avoid conflicts
        // with shell shortcuts like Ctrl+H (used by Ctrl+Backspace)
        bind "Alt h" { MoveFocus "left"; }
        bind "Alt l" { MoveFocus "right"; }
        bind "Alt j" { MoveFocus "down"; }
        bind "Alt k" { MoveFocus "up"; }
    }
}
