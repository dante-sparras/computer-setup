// Zellij configuration
// Theme: onedark

theme "onedark"

default_layout "compact"
default_shell "zsh"

copy_on_select true
mouse_mode true

keybinds {
    normal {
        // Resize panes
        bind "Alt Shift h" { Resize "Left"; }
        bind "Alt Shift j" { Resize "Down"; }
        bind "Alt Shift k" { Resize "Up"; }
        bind "Alt Shift l" { Resize "Right"; }

        // Close pane
        bind "Alt q" { CloseFocus; }

        // Split panes - easier shortcuts
        bind "Alt h" { NewPane "Down"; }     // Horizontal split
        bind "Alt v" { NewPane "Right"; }    // Vertical split
    }
}
