// Zellij configuration with zjstatus (One Dark theme)

theme "onedark"

default_layout "compact"
default_shell "zsh"

pane_frames false
simplified_ui true

copy_on_select true
mouse_mode true

plugins {
    zjstatus {
        location "file:~/.config/zellij/plugins/zjstatus.wasm"
    }
}

load_zjstatus {
    hide_frame_for_single_pane "true"

    // One Dark colors
    format_left  "#[fg=#61afef,bg=#282c34,bold] {mode} #[fg=#abb2bf,bg=#282c34,bold]{session}#[bg=#282c34] {tabs}"
    format_right "#[fg=#5c6370,bg=#282c34] {command_kubectx} {command_kubens}#[fg=#abb2bf,bg=#282c34] {datetime} "
    format_space "#[bg=#282c34]"

    mode_normal          "#[bg=#61afef,fg=#282c34] "
    mode_tmux            "#[bg=#e5c07b,fg=#282c34] "
    mode_default_to_mode "tmux"

    tab_normal               "#[fg=#5c6370,bg=#282c34] {index} {name} {fullscreen_indicator}{sync_indicator}{floating_indicator}"
    tab_active               "#[fg=#abb2bf,bg=#282c34,bold,italic] {index} {name} {fullscreen_indicator}{sync_indicator}{floating_indicator}"
    tab_fullscreen_indicator "□ "
    tab_sync_indicator       "  "
    tab_floating_indicator   "󰉈 "

    command_kubectx_command  "kubectx -c"
    command_kubectx_format   "#[fg=#5c6370,bg=#282c34,italic] {stdout}"
    command_kubectx_interval "2"

    command_kubens_command  "kubens -c"
    command_kubens_format   "#[fg=#5c6370,bg=#282c34]{stdout} "
    command_kubens_interval "2"

    datetime          "#[fg=#abb2bf,bg=#282c34] {format} "
    datetime_format   "%a %d %b %H:%M"
    datetime_timezone "Europe/Berlin"
}

// Navigation keybinds (Lightning style)
keybinds {
    shared {
        bind "Alt n" { NewPane; }
        bind "Alt Enter" { NewPane; }
        bind "Alt x" { CloseFocus; }
        bind "Alt q" { CloseFocus; }

        bind "Alt Left" { MoveFocus "left"; }
        bind "Alt Right" { MoveFocus "right"; }
        bind "Alt Up" { MoveFocus "up"; }
        bind "Alt Down" { MoveFocus "down"; }

        bind "Alt h" { NewPane "down"; }
        bind "Alt v" { NewPane "right"; }

        bind "Alt Shift Left" { Resize "Increase Left"; }
        bind "Alt Shift Right" { Resize "Increase Right"; }
        bind "Alt Shift Up" { Resize "Increase Up"; }
        bind "Alt Shift Down" { Resize "Increase Down"; }
    }

    locked {
        bind "Ctrl g" { SwitchToMode "Normal"; }
    }

    normal {
        bind "Ctrl g" { SwitchToMode "Locked"; }
        bind "Ctrl p" { SwitchToMode "Pane"; }
        bind "Ctrl t" { SwitchToMode "Tab"; }
        bind "Ctrl n" { SwitchToMode "Resize"; }
        bind "Ctrl o" { SwitchToMode "Session"; }
        bind "Ctrl s" { SwitchToMode "Scroll"; }
    }

    pane {
        bind "h" { MoveFocus "left"; }
        bind "j" { MoveFocus "down"; }
        bind "k" { MoveFocus "up"; }
        bind "l" { MoveFocus "right"; }
        bind "Ctrl p" { SwitchToMode "Normal"; }
    }

    tab {
        bind "h" { GoToPreviousTab; }
        bind "l" { GoToNextTab; }
        bind "Ctrl t" { SwitchToMode "Normal"; }
    }
}